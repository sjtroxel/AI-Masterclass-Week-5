{
  "name": "poster-pilot",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=shared && npm run build --workspace=client && npm run build --workspace=server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --project client/tsconfig.json && tsc --noEmit --project server/tsconfig.json && tsc --noEmit --project shared/tsconfig.json",
    "ingest": "tsx server/src/workers/ingestWorker.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "vitest related --run"
    ]
  },
  "overrides": {
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
