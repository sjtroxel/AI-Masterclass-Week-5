# === Anthropic / LLM ===
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# === External APIs ===
# DPLA (Digital Public Library of America) — primary poster data source.
# Register for a free API key at: https://dp.la/info/developers/codex/
DPLA_API_KEY=your-dpla-api-key-here
REPLICATE_API_KEY=your-replicate-api-key-here
# NARA_API_KEY is legacy — the NARA Catalog API is currently offline.
# Kept here for future restoration. Leave blank or omit entirely.
# NARA_API_KEY=your-nara-api-key-here

# === CLIP Model ===
# Replicate version hash for openai/clip (768-dim ViT-L/14).
# Accepts both `text` and `image` inputs in the same embedding space.
# (cjwbw/clip-vit-large-patch14 only exposes the image encoder — do not use for text search.)
# Current hash: fd95fe35085b5b9a63d830d3126311ee6b32a7a976c78eb5f210a3a007bcdda6
# Requires Replicate account with billing credit to run.
CLIP_MODEL_VERSION=fd95fe35085b5b9a63d830d3126311ee6b32a7a976c78eb5f210a3a007bcdda6

# === Server ===
PORT=3001
# Comma-separated list of allowed CORS origins.
# Add additional dev ports as needed (e.g. 5175 for a second Vite instance).
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5175
